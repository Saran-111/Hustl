<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_back"
            android:background="@drawable/bg_icon_btn"
            android:padding="8dp"
            android:contentDescription="Back"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Create a Gig"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"/>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingBottom="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tell buyers what you can do for them."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="24dp"/>

            <!-- Gig Title -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="GIG TITLE" android:textSize="11sp" android:textColor="@color/text_secondary"
                android:letterSpacing="0.08" android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/gig_title_hint"
                android:background="@drawable/bg_input"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:maxLines="2"
                android:layout_marginBottom="16dp"/>

            <!-- Category -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="CATEGORY" android:textSize="11sp" android:textColor="@color/text_secondary"
                android:letterSpacing="0.08" android:layout_marginBottom="8dp"/>
            <Spinner
                android:id="@+id/spinnerCategory"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:paddingHorizontal="14dp"
                android:layout_marginBottom="16dp"
                android:entries="@array/categories"/>

            <!-- Description -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="DESCRIPTION" android:textSize="11sp" android:textColor="@color/text_secondary"
                android:letterSpacing="0.08" android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/etDescription"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:hint="Describe your gig in detail — your process, what's included, turnaround time…"
                android:background="@drawable/bg_input"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:gravity="top"
                android:inputType="textMultiLine"
                android:layout_marginBottom="16dp"/>

            <!-- Pricing -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="BASIC PRICE (₹)" android:textSize="11sp" android:textColor="@color/text_secondary"
                android:letterSpacing="0.08" android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/etBasicPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="999"
                android:background="@drawable/bg_input"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:inputType="number"
                android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="STANDARD PRICE (₹)" android:textSize="11sp" android:textColor="@color/text_secondary"
                android:letterSpacing="0.08" android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/etStandardPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="2499"
                android:background="@drawable/bg_input"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:inputType="number"
                android:layout_marginBottom="16dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="PREMIUM PRICE (₹)" android:textSize="11sp" android:textColor="@color/text_secondary"
                android:letterSpacing="0.08" android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/etPremiumPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="4999"
                android:background="@drawable/bg_input"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:inputType="number"
                android:layout_marginBottom="16dp"/>

            <!-- Tags -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="TAGS (comma separated)" android:textSize="11sp" android:textColor="@color/text_secondary"
                android:letterSpacing="0.08" android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/etTags"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="logo, branding, minimal"
                android:background="@drawable/bg_input"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="12dp"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnPublish"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Publish Gig ✦"
                android:background="@drawable/bg_btn_accent"
                android:textColor="@color/bg"
                android:textSize="16sp"
                android:textStyle="bold"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
